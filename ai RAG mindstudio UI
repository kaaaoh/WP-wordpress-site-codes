<!-- ============================================================
     MindStudio RAG Agent Embed (Optimized for Lennon's Site)
     Platform : WordPress + Gutenberg + Divi 5
     Update   : Shortened hint delay & expanded sandbox permissions
     ============================================================ -->

<div class="ms-chat-wrapper">

  <!-- Loading Spinner -->
  <div class="ms-loader" id="ms-loader" aria-hidden="true">
    <div class="ms-loader__spinner"></div>
    <p class="ms-loader__text">Connecting to AI Assistant…</p>
  </div>

  <!-- Fallback -->
  <div class="ms-fallback" id="ms-fallback" role="alert" hidden>
    <p>⚠️ The AI assistant could not load. Please
      <a href="mailto:your@yourdomain.com">contact me directly</a>.
    </p>
  </div>

  <!-- MindStudio Embed iframe -->
  <iframe
    id="ms-chat-frame"
    src="YOUR_MINDSTUDIO_EMBED_URL"
    title="AI Career Assistant"
    allow="clipboard-read; clipboard-write; microphone"
    loading="lazy"
    /* Added allow-popups-to-escape-sandbox for LinkedIn/Resume links */
    sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"
    class="ms-chat-frame"
  ></iframe>

  <!-- Timed scroll hint (appears after 10s) -->
  <div class="ms-scroll-hint" id="ms-scroll-hint" aria-hidden="true">
    <span>More about me below</span>
    <div class="ms-scroll-hint__arrow">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M8 3v10M3 9l5 5 5-5" stroke="#6b7280" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

</div>

<style>
  .ms-chat-wrapper {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    height: 100dvh;
    min-height: 500px;
    background-color: #f4f4f5;
    overflow: hidden;
  }

  .ms-loader {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: #f4f4f5;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  .ms-loader__spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #d1d5db;
    border-top-color: #6366f1;
    border-radius: 50%;
    animation: ms-spin 0.8s linear infinite;
  }

  .ms-loader__text {
    font-size: 13px;
    color: #6b7280;
    margin: 0;
    font-family: sans-serif;
  }

  @keyframes ms-spin {
    to { transform: rotate(360deg); }
  }

  .ms-chat-frame {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ms-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: #f4f4f5;
    z-index: 10;
  }

  .ms-scroll-hint {
    position: absolute;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
    z-index: 20;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .ms-scroll-hint.is-visible {
    opacity: 0.7;
  }

  .ms-scroll-hint span {
    font-size: 11px;
    color: #6b7280;
    display: block;
    margin-bottom: 8px;
    font-family: sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ms-scroll-hint__arrow {
    margin: 0 auto;
    animation: ms-bounce 1.6s ease-in-out infinite;
  }

  @keyframes ms-bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(6px); }
  }
</style>

<script>
  (function () {
    // ⏱ Delay shortened to 10 seconds (10000ms)
    var HINT_DELAY_MS = 10000;

    function initMsChat() {
      var frame    = document.getElementById('ms-chat-frame');
      var loader   = document.getElementById('ms-loader');
      var fallback = document.getElementById('ms-fallback');
      var hint     = document.getElementById('ms-scroll-hint');

      if (!frame) return;

      frame.addEventListener('load', function () {
        frame.style.opacity = '1';
        if (loader) {
          loader.style.opacity = '0';
          setTimeout(function () { loader.hidden = true; }, 350);
        }
      });

      frame.addEventListener('error', function () {
        if (loader)   loader.hidden   = true;
        if (fallback) fallback.hidden = false;
        frame.hidden = true;
      });

      if (hint) {
        var hintTimer = setTimeout(function () {
          hint.classList.add('is-visible');
        }, HINT_DELAY_MS);

        window.addEventListener('scroll', function hideHint() {
          clearTimeout(hintTimer);
          hint.classList.remove('is-visible');
          window.removeEventListener('scroll', hideHint);
        }, { passive: true, once: true });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMsChat);
    } else {
      initMsChat();
    }
  })();
</script>
