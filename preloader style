/* 1. THE MAIN CONTAINER */
#ss-preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000000;
    z-index: 99999;
    /* Remove display: none; */
    display: flex; 
    justify-content: center;
    align-items: center;
    transition: transform 0.8s cubic-bezier(0.85, 0, 0.15, 1);
}

/* This class will be used to show it only when needed */
#ss-preloader.is-active {
    display: flex;
}

/* 2. THE SLIDE-UP ANIMATION */
.loader-hidden {
    transform: translateY(-100%);
}

/* 3. THE DYNAMIC WINDOW */
/* We use 'em' so the window height is always relative to the font size */
.text-window {
    /* Instead of height: 40px, we use a 'Line Clamp' approach 
       or simply ensure it matches the height of one span */
    height: 1.2em; /* This makes the window height relative to the font size */
    overflow: hidden;
    position: relative;
}

/* 4. THE ROLLING STACK */
#loader-text-stack {
    display: flex;
    flex-direction: column;
    /* Faster transition (0.3s) with a snappy 'back' effect */
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* 5. THE TEXT STYLING */
.loader-text {
    height: auto; /* Height: auto allows the JS to measure the real offsetHeight */
    line-height: 1.2; /* relative value, adjusts to screen size */
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-weight: 900; /* Extra bold for snappiness */
    font-size: 24px;
    letter-spacing: 2px; /* Slightly tighter for speed */
    text-transform: uppercase;
    text-align: center;
}

/* 6. THE ACCENT BAR */
.loader-bar {
    width: 60px;
    height: 2px;
    background: #ffffff;
    margin: 10px auto 0;
}
